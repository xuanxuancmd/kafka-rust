        partition: Option<i32>,
        key_schema: Option<Arc<dyn Schema>>,
        key: Option<Arc<dyn Any + Send + Sync>>,
        value_schema: Option<Arc<dyn Schema>>,
        value: Option<Arc<dyn Any + Send + Sync>>,
